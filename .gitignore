#   using pyenv. But see: https://github.com/pyenv/pyenv/issues/530
#.python-version

# pipenv
#   According to pypa/pipenv#599, stdlib's pipenv uses Pipfile & Pipfile.lock
#   which should be tracked unless you have a good reason not to.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally tracked.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally tracked.
#pdm.lock

